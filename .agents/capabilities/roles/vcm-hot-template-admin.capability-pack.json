{
  "schema_version": "1.0",
  "id": "vcm-hot-template-admin-capability-pack",
  "role": "developer",
  "label": "VCM Hot Template Admin Developer Agent",
  "summary": "Admin-console development capabilities extracted from vcm-imagetext-platform for Vite React, BackendSpec-driven integration, state handling, tests, QA build, and drift checks.",
  "source_project": {
    "id": "vcm-imagetext-platform",
    "label": "VCM ImageText Admin Platform",
    "kind": "admin_console",
    "local_path": "/Users/xy/xykj/vcm-imagetext-platform",
    "entry_documents": ["AGENTS.md", "package.json", "bdd", "scripts"]
  },
  "agent_endpoint": {
    "tenant_id": "local-demo",
    "user_id": "dev_vcm_user",
    "role": "developer",
    "agent_endpoint_id": "dev_vcm_hot_template_local",
    "execution_mode": "manual_confirm",
    "executor": {
      "kind": "codex_cli",
      "label": "Codex CLI",
      "command": "codex"
    },
    "approval_policy": {
      "mode": "manual_confirm",
      "require_human_for": [
        "run_command",
        "write_file",
        "local_build",
        "qa_mutation",
        "submit_task"
      ],
      "allow_auto_for": [
        "read_file",
        "read_repo",
        "inspect_diff",
        "draft_report"
      ]
    }
  },
  "capability_sources": [
    {
      "id": "vcm_skill_backendspec_alignment",
      "type": "skill",
      "name": "BackendSpec alignment",
      "summary": "Treat BackendSpec as the source of truth for hot template admin integration and avoid inventing backend behavior.",
      "capabilities": ["backendspec_parse", "api_contract_alignment"],
      "approval_mode": "prompt_only",
      "enabled": true,
      "metadata": {
        "path": "AGENTS.md",
        "mention_slug": "backendspec-alignment"
      }
    },
    {
      "id": "vcm_skill_admin_state_machine",
      "type": "skill",
      "name": "Admin page state handling",
      "summary": "Implement success, failure, empty, loading, and recovery states for admin-console workflows.",
      "capabilities": ["state_machine", "admin_console_ux"],
      "approval_mode": "manual_confirm",
      "enabled": true,
      "metadata": {
        "path": "src",
        "mention_slug": "admin-state-machine"
      }
    },
    {
      "id": "vcm_skill_vite_react_testing",
      "type": "skill",
      "name": "Vite React testing",
      "summary": "Use Vitest, TypeScript check, lint, and build scripts for focused admin-console verification.",
      "capabilities": ["vitest", "typescript_check", "vite_build"],
      "approval_mode": "manual_confirm",
      "enabled": true,
      "metadata": {
        "path": "package.json",
        "mention_slug": "vite-react-testing"
      }
    },
    {
      "id": "vcm_skill_medi_server_url",
      "type": "skill",
      "name": "mediServerUrl integration",
      "summary": "Use the repository mediServerUrl integration path for backend API access instead of ad hoc endpoint construction.",
      "capabilities": ["medi_server_url", "api_client_alignment"],
      "approval_mode": "prompt_only",
      "enabled": true,
      "metadata": {
        "path": "src",
        "mention_slug": "medi-server-url"
      }
    }
  ],
