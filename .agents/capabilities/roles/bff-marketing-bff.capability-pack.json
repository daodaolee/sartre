{
  "schema_version": "1.0",
  "id": "bff-marketing-bff-capability-pack",
  "role": "developer",
  "label": "FalcoCut BFF Developer Agent",
  "summary": "BFF development capabilities extracted from marketing-bff-server for NestJS service work, DDD boundaries, legacy contracts, MySQL adapters, BDD, and harness verification.",
  "source_project": {
    "id": "marketing-bff-server",
    "label": "FalcoCut Marketing BFF Server",
    "kind": "bff_service",
    "local_path": "/Users/xy/xykj/marketing-bff-server",
    "entry_documents": ["AGENTS.md", "package.json", "bdd", "scripts"]
  },
  "agent_endpoint": {
    "tenant_id": "local-demo",
    "user_id": "dev_bff_user",
    "role": "developer",
    "agent_endpoint_id": "dev_bff_falcocut_local",
    "execution_mode": "manual_confirm",
    "executor": {
      "kind": "codex_cli",
      "label": "Codex CLI",
      "command": "codex"
    },
    "approval_policy": {
      "mode": "manual_confirm",
      "require_human_for": [
        "run_command",
        "write_file",
        "local_build",
        "qa_mutation",
        "prod_mutation",
        "submit_task"
      ],
      "allow_auto_for": [
        "read_file",
        "read_repo",
        "inspect_diff",
        "draft_report"
      ]
    }
  },
  "capability_sources": [
    {
      "id": "bff_skill_nestjs_service_boundary",
      "type": "skill",
      "name": "NestJS service boundary",
      "summary": "Implement BFF changes inside NestJS module boundaries with application services, repositories, and adapters kept separate.",
      "capabilities": [
        "nestjs_module",
        "service_boundary",
        "repository_adapter"
      ],
      "approval_mode": "prompt_only",
      "enabled": true,
      "metadata": {
        "path": "AGENTS.md",
        "mention_slug": "nestjs-service-boundary"
      }
    },
    {
      "id": "bff_skill_bdd_contract_harness",
      "type": "skill",
      "name": "BDD and contract harness",
      "summary": "Use BDD and harness scripts for regression, acceptance, drift, and legacy contract reports.",
      "capabilities": ["bdd", "regression_harness", "legacy_contract_report"],
      "approval_mode": "manual_confirm",
      "enabled": true,
      "metadata": {
        "path": "bdd",
        "mention_slug": "bdd-contract-harness"
      }
    },
    {
      "id": "bff_skill_mysql_local_adapter",
      "type": "skill",
      "name": "Local MySQL adapter",
      "summary": "Use the repository local MySQL docker compose path only when a task explicitly needs local database verification.",
      "capabilities": ["mysql_local", "repository_verification"],
      "approval_mode": "manual_confirm",
      "enabled": true,
      "metadata": {
        "path": "compose/mysql/docker-compose.yml",
        "mention_slug": "mysql-local-adapter"
      }
    },
    {
      "id": "bff_skill_legacy_compatibility",
      "type": "skill",
      "name": "Legacy compatibility",
      "summary": "Preserve Java legacy and downstream API compatibility through explicit contract checks.",
      "capabilities": ["legacy_contract", "api_compatibility"],
      "approval_mode": "manual_confirm",
      "enabled": true,
      "metadata": {
        "path": "scripts/legacy-contract-report.sh",
        "mention_slug": "legacy-compatibility"
      }
    }
  ],
  "commands": [
    {
