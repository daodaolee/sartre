  "hooks": [
    {
      "id": "dev.bff.hook.task-received",
      "slug": "task-received",
      "label": "Prepare BFF task prompt",
      "summary": "When a BFF task is accepted, project module boundaries, relevant scripts, and contract constraints into Codex context.",
      "trigger": "delivery.accepted",
      "capabilities": ["project_context_projection"],
      "approval_mode": "prompt_only",
      "enabled": true
    }
  ],
  "constraints": [
    {
      "id": "dev.bff.constraint.library-first",
      "slug": "library-first",
      "label": "Library-first implementation",
      "summary": "Prefer repository libraries, modules, and adapters over ad hoc cross-boundary code.",
      "severity": "blocking",
      "source": "AGENTS.md"
    },
    {
      "id": "dev.bff.constraint-test-first",
      "slug": "test-first",
      "label": "Test-first service changes",
      "summary": "Behavioral BFF changes must be covered by focused tests or harness evidence.",
      "severity": "blocking",
      "source": "package.json"
    },
    {
      "id": "dev.bff.constraint-legacy-contract",
      "slug": "legacy-contract",
      "label": "Legacy contract compatibility",
      "summary": "Changes touching legacy boundaries must keep downstream contracts explicit and verifiable.",
      "severity": "blocking",
      "source": "scripts/legacy-contract-report.sh"
    }
  ],
  "metadata": {
    "mention_prefix": "dev.bff"
  }
