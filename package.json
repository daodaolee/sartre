{
  "name": "sartre",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "hub:dev": "pnpm --filter @sartre/hub-api dev",
    "hub:demo:local": "pnpm --filter @sartre/hub-api demo:local",
    "connector:demo:local": "pnpm --filter @sartre/hub-api demo:connector-local",
    "hub:test": "pnpm --filter @sartre/hub-api test",
    "hub:build": "pnpm --filter @sartre/hub-api build",
    "web:dev": "pnpm --filter @sartre/web-console dev",
    "web:test": "pnpm --filter @sartre/web-console test",
    "web:build": "pnpm --filter @sartre/web-console build",
    "web:smoke:hub": "vitest run scripts/web-console-hub-real-smoke.test.ts",
    "domain:test": "pnpm --filter @sartre/domain test",
    "contracts:test": "pnpm --filter @sartre/contracts test",
    "pg:dev:start": "bash scripts/postgres17-dev.sh start",
    "pg:dev:stop": "bash scripts/postgres17-dev.sh stop",
    "pg:dev:status": "bash scripts/postgres17-dev.sh status",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "architecture:check": "tsx scripts/architecture-check.ts",
    "harness:evidence": "tsx scripts/evidence-gate.ts",
    "lint": "biome check .",
    "lint:v0.2": "biome check package.json apps/hub-api apps/connector-cli apps/web-console packages/domain packages/contracts packages/sdk scripts/architecture-check.ts scripts/postgres17-dev.sh",
    "lint:lane-a": "biome check package.json apps/hub-api apps/web-console apps/connector-cli packages/domain packages/contracts packages/sdk packages/connector-core scripts/architecture-check.ts scripts/architecture-check.test.ts scripts/evidence-gate.ts scripts/evidence-gate.test.ts scripts/web-console-hub-real-smoke.test.ts scripts/postgres17-dev.sh",
    "format:check": "biome format . --write=false",
    "doctor": "./scripts/doctor.sh",
    "harness:regression": "./scripts/harness-regression.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@fission-ai/openspec": "^1.4.0",
    "@nestjs/testing": "^11.1.27",
    "@sartre/sdk": "workspace:*",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  }
}
